{
  "editor.cursorBlinking": "solid",
  "background.backgroundOpacity": [0.95, 0.1, 0.1, 0.1],
  "editor.fontFamily": "'Cascadia Mono'",
  "editor.minimap.enabled": false,
  "cmake.showOptionsMovedNotification": false,
  "breadcrumbs.enabled": false,
  "editor.renderWhitespace": "all",
  "workbench.colorTheme": "Rosé Pine Moon (no italics)",
  "editor.lineNumbers": "relative",
  "vim.leader": "<Space>",
  "vim.hlsearch": true,
  "workbench.sideBar.location": "right",
  "liveServer.settings.CustomBrowser": "chrome",
  "vim.normalModeKeyBindingsNonRecursive": [
    //nice to have
    {
      "before": ["leader", "s"],
      "commands": [{ "command": "editor.action.showDefinitionPreviewHover" }]
    },
    {
      "before": ["leader", "w"],
      "commands": [":w!"]
    },
    {
      "before": ["leader", "q"],
      "commands": [":q!"]
    },
    {
      "before": ["leader", "x"],
      "commands": [":x!"]
    },
    {
      "before": ["leader", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["leader", "p"],
      "commands": ["editor.action.formatDocument"]
    },
    //for commenting lines
    {
      "before": ["leader", "c"],
      "commands": ["editor.action.commentLine"]
    },
    // to switch between editor tabs
    {
      "before": ["leader", "l"],
      "commands": ["workbench.action.nextEditor"]
    },
    {
      "before": ["leader", "h"],
      "commands": ["workbench.action.previousEditor"]
    },
    // to center everytime i use pg up and dn
    {
      "before": ["c-d"],
      "after": ["M", "c-d"]
    },
    {
      "before": ["c-u"],
      "after": ["M", "c-u"]
    }
  ],
  "vim.visualModeKeyBindings": [
    //nice to have
    {
      "before": ["leader", "w"],
      "commands": [":w!"]
    },
    {
      "before": ["leader", "q"],
      "commands": [":q!"]
    },
    {
      "before": ["leader", "x"],
      "commands": [":x!"]
    },
    //navigation and file tree
    {
      "before": ["leader", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["leader", "p"],
      "commands": ["editor.action.formatDocument"]
    },
    //for commenting lines
    {
      "before": ["leader", "c"],
      "commands": ["editor.action.commentLine"]
    },
    // to switch between editor tabs
    {
      "before": ["leader", "l"],
      "commands": ["workbench.action.nextEditor"]
    },
    {
      "before": ["leader", "h"],
      "commands": ["workbench.action.previousEditor"]
    },
    //move selected lines while being in visual mode
    {
      "before": ["K"],
      "commands": ["editor.action.moveLinesUpAction"]
    },
    {
      "before": ["J"],
      "commands": ["editor.action.moveLinesDownAction"]
    },
    //for indenting and unindenting
    {
      "before": ["<"],
      "commands": ["editor.action.outdentLines"]
    },
    {
      "before": [">"],
      "commands": ["editor.action.indentLines"]
    },
    // for comments in visual mode
    {
      "before": ["leader", "c"],
      "commands": ["editor.action.commentLine"]
    }
  ],
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.tabSize": 4,
  "[sass][javascript]": {
    "editor.tabSize": 2
  },
  "editor.lineHeight": 1.75,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
