root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{sh,bash}]
indent_size = 4

[*.lua]
indent_size = 4

[*.{json,toml,yml,yaml}]
indent_size = 2

[*.css]
indent_size = 4

[Makefile]
indent_style = tab
